# FDA API 配置
FDA_API_KEY=your_fda_api_key_here
FDA_API_BASE_URL=https://api.fda.gov

# OpenAI API 配置（用于生成摘要）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# 数据库配置
DB_PATH=./data/mdr_database.db

# 定时任务配置
CRON_SCHEDULE=0 2 * * *

# 服务器配置
PORT=3000
NODE_ENV=development

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log
